# Which provider the harness calls directly. "anthropic" (default) or "openai".
VITE_LLM_PROVIDER=anthropic

# Anthropic (used when VITE_LLM_PROVIDER=anthropic)
VITE_ANTHROPIC_API_KEY=sk-ant-your-key
VITE_ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (used when VITE_LLM_PROVIDER=openai)
VITE_OPENAI_API_KEY=sk-your-key
VITE_OPENAI_MODEL=gpt-5.5

# NOTE: keys here are bundled into the client (browser-direct calls). Local/demo use only.
